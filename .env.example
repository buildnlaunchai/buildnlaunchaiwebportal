# Copy to .env.local and fill in. .env.local is gitignored and must stay that way.

NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

RESEND_API_KEY=
RESEND_FROM_EMAIL=

NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Cloudflare R2 — public asset storage (tool cover thumbnails). Server-only.
# These are ORDINARY secrets and may live in Vercel: they only grant write to a
# bucket of PUBLIC images and cannot decrypt anything (unlike ENCRYPTION_KEY,
# below, which must never be on Vercel). See lib/r2.ts.
#   R2_PUBLIC_BASE_URL — the bucket's public URL (r2.dev or a custom domain),
#                        no trailing slash, e.g. https://pub-xxxx.r2.dev
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_BASE_URL=

# Shared secret proving "our backend sent this" to the run-tool Edge Function.
# Set the SAME value in Supabase secrets (supabase secrets set RUNNER_SECRET=...)
# AND here / in Vercel (server-only). It cannot decrypt anything — ENCRYPTION_KEY
# is not on Vercel — so it does not weaken the §13 property.
RUNNER_SECRET=

# ---------------------------------------------------------------------------
# ENCRYPTION_KEY IS DELIBERATELY NOT IN THIS FILE. NOBODY FORGOT IT.
#
# It encrypts members' API keys, and it lives in Supabase secrets and nowhere
# else — not here, not in .env.local, and above all NOT IN VERCEL. The only code
# that reads it is supabase/functions/_shared/crypto.ts, which only ever runs on
# Supabase.
#
# That absence is what lets us say: a total compromise of the Vercel project
# yields ciphertext and nothing else. Adding it here would quietly destroy the
# security property in CLAUDE.md §13.
#
# Set it once, at setup, and back it up:
#     supabase secrets set ENCRYPTION_KEY="$(openssl rand -base64 32)"
#
# If you lose it, every member's stored API key is permanently unrecoverable.
# ---------------------------------------------------------------------------
